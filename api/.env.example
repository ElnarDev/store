# ============================================================
# CONFIGURACIÓN DE BASE DE DATOS - SUPABASE
# ============================================================
# Copia este archivo como ".env" y rellena los valores reales.
# Los datos los encuentras en: Supabase Dashboard → Connect → Session Pooler → View parameters
#
# NUNCA subas el archivo .env a GitHub.
# ============================================================

# Cadena de conexión completa para Prisma/backend
# Formato: postgresql://[user]:[password]@[host]:[port]/[database]
DATABASE_URL=postgresql://postgres.[tu-project-ref]:[tu-password]@aws-1-sa-east-1.pooler.supabase.com:5432/postgres

# URL pública de tu proyecto Supabase
# La encuentras en: Supabase Dashboard → Settings → API
SUPABASE_URL=https://[tu-project-ref].supabase.co

# Clave anónima (pública) — para el cliente frontend
# La encuentras en: Supabase Dashboard → Settings → API → anon public
SUPABASE_ANON_KEY=[tu-anon-key]

# Clave de servicio (privada) — SOLO para el backend, nunca en el frontend
# La encuentras en: Supabase Dashboard → Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=[tu-service-role-key]
